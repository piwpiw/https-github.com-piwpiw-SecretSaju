# ========================================
# Kakao Login (필수)
# ========================================
# https://developers.kakao.com/에서 발급받은 키
NEXT_PUBLIC_KAKAO_JS_KEY=your_javascript_key_here
KAKAO_REST_API_KEY=your_rest_api_key_here
KAKAO_CLIENT_SECRET=your_client_secret_here

# ========================================
# Application URL
# ========================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ========================================
# Supabase (Phase 4 연동 시)
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ========================================
# Toss Payments (Phase 4 연동 시)
# ========================================
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
NEXT_PUBLIC_TOSS_SUCCESS_URL=http://localhost:3000/payment/success
NEXT_PUBLIC_TOSS_FAIL_URL=http://localhost:3000/payment/fail
