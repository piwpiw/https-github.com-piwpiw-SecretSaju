{
  "name": "secret-paws",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run guard:result-card && next build",
    "start": "next start",
    "lint": "next lint",
    "qa": "node scripts/zero-script-qa.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "deploy": "node scripts/pre-deploy.js --parallel-checks && node scripts/render-deploy.js && node scripts/wait-for-health.js",
    "deploy:preview": "node scripts/pre-deploy.js --skip-build --skip-tests --parallel-checks && node scripts/render-deploy.js",
    "deploy:fast": "node scripts/pre-deploy.js --skip-build --parallel-checks && node scripts/render-deploy.js && node scripts/wait-for-health.js",
    "deploy:preview:fast": "node scripts/pre-deploy.js --skip-build --skip-tests --parallel-checks && node scripts/render-deploy.js",
    "deploy:webhook": "node scripts/render-deploy.js",
    "deploy:health": "node scripts/wait-for-health.js",
    "deploy:ci": "node scripts/render-deploy.js && node scripts/wait-for-health.js",
    "pre-deploy:parallel": "node scripts/pre-deploy.js --parallel-checks",
    "preflight:local:parallel": "node scripts/preflight-local.js --parallel",
    "preflight:local:serial": "npm run lint && npx tsc --noEmit",
    "preflight:local": "node scripts/preflight-local.js --parallel",
    "deploy:local": "npm run preflight:local && node scripts/pre-deploy.js --skip-build --skip-tests",
    "guard:result-card": "node scripts/guard-result-card.js",
    "verify:env": "node scripts/verify-env.js",
    "setup:env": "bash scripts/setup-env.sh",
    "setup:github": "bash scripts/setup-github.sh",
    "setup:render": "bash scripts/setup-vercel.sh",
    "setup:vercel": "bash scripts/setup-vercel.sh",
    "setup:complete": "bash scripts/complete-setup.sh",
    "setup:auto": "node scripts/auto-deploy.js",
    "open:setup": "node scripts/open-setup-pages.js",
    "migrate:db": "node scripts/migrate-db.js",
    "pre-deploy": "node scripts/pre-deploy.js"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@notionhq/client": "^5.9.0",
    "@portone/browser-sdk": "^0.1.3",
    "@react-email/components": "^1.0.8",
    "@vercel/analytics": "^1.6.1",
    "@supabase/supabase-js": "^2.97.0",
    "@tosspayments/payment-sdk": "^1.9.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/pg": "^8.18.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^11.18.2",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.454.0",
    "next": "14.2.18",
    "next-mdx-remote": "^6.0.0",
    "openai": "^6.25.0",
    "pg": "^8.19.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.9.2",
    "stripe": "^20.3.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
